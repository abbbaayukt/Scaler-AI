# Backend environment variables
# Copy this file to .env and fill in your values

# ---- Database ----
# Leave blank to use SQLite locally (default)
# For Railway PostgreSQL, paste the connection string here:
DATABASE_URL=

# ---- Auth ----
# Change this to a long random secret in production!
SECRET_KEY=supersecretkey_changeme_in_production_please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---- Frontend URL (for CORS) ----
# Set to your Vercel deployment URL in production
# e.g. https://flipkart-clone.vercel.app
FRONTEND_URL=http://localhost:5173

# ---- Email (optional) ----
# If blank, order emails are printed to the terminal
MAIL_API_KEY=
